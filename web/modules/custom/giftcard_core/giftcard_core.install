<?php

/**
 * @file
 * Install, update and uninstall functions for the Gift Card Core module.
 */

/**
 * Implements hook_uninstall().
 */
function giftcard_core_uninstall(): void {
  \Drupal::configFactory()->getEditable('giftcard_core.settings')->delete();
}

/**
 * Implements hook_requirements().
 */
function giftcard_core_requirements(string $phase): array {
  $requirements = [];

  if ($phase === 'runtime') {
    $config = \Drupal::config('giftcard_core.settings');

    if (empty($config->get('currency'))) {
      $requirements['giftcard_core_currency'] = [
        'title'       => t('Gift Card Core'),
        'description' => t('Currency code is not configured. Visit <a href=":url">Gift Card Settings</a>.', [
          ':url' => \Drupal::url('giftcard_core.settings'),
        ]),
        'severity' => REQUIREMENT_WARNING,
      ];
    }
  }

  return $requirements;
}

/**
 * Rename the rapyd_payment_id field to payment_id on the gift_card table.
 */
function giftcard_core_update_8001(): void {
  $database = \Drupal::database();
  $schema   = $database->schema();

  if ($schema->fieldExists('gift_card', 'rapyd_payment_id') && !$schema->fieldExists('gift_card', 'payment_id')) {
    $schema->addField('gift_card', 'payment_id', [
      'type'     => 'varchar',
      'length'   => 255,
      'not null' => FALSE,
      'default'  => '',
    ]);
    $database->update('gift_card')
      ->expression('payment_id', 'rapyd_payment_id')
      ->execute();

    $schema->dropField('gift_card', 'rapyd_payment_id');
  }

  \Drupal::entityDefinitionUpdateManager()->applyUpdates();
}
